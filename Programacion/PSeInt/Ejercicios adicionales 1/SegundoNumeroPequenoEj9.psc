Algoritmo SegundoNumeroPequenoEj9
	Definir x,y,z Como real;
	Escribir "Introduce tres números y yo te diré si el segundo número es el más pequeńo o no";
	Escribir Sin Saltar "Primer número: ";
	Leer x;
	Escribir Sin Saltar "Segundo número: ";
	Leer y;
	Escribir Sin Saltar "Tercer número: ";
	Leer z;
	Si y<x & y<z Entonces
		Escribir "El segundo número es el más pequeńo";
	SiNo
		Escribir "El segundo número no es el más pequeńo";
	FinSi
	
FinAlgoritmo
