Algoritmo DosPalabrasIgualesEj4
	Definir x,y Como Caracter;
	Escribir "Introduce dos palabras y yo te diré si son iguales o no";
	Escribir Sin Saltar "Primera palabra: ";
	Leer x;
	Escribir Sin Saltar "Segunda palabra: ";
	Leer y;
	Si x==y Entonces
		Escribir "Las dos palabras son iguales";
	SiNo
		Escribir "Las dos palabras no son iguales";
	FinSi
	
FinAlgoritmo
