//El usuario introduce un nºmero y el programa le dice si es par o impar
Algoritmo ParImparEj2
	Definir x como Entero;//Definiciµn de variable
	//Presentaciµn e introducciµn de nºmero
	Escribir Sin Saltar "Introduce un nºmero: ";
	Leer x;
	//Procedimiento
	Si x=(x%2) Entonces
		Escribir "El nºmero es par";
	SiNo
		Escribir "El nºmero es impar";
	FinSi
FinAlgoritmo
