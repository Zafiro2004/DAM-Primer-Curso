//El usuario introduce un nºmero y el programa le dice si es positivo o negativo
Algoritmo PositivoNegativoEj1
	Definir x Como Real;//Definiciµn de varable
	//Presentaciµn e introducciµn del nºmero
	Escribir "Introduce un nºmero positivo o negativo";
	Leer x;
	//Procedimiento
	Si x>0 Entonces
		Escribir "Es positivo";
	SiNo
		Escribir "Es negativo";
	FinSi
FinAlgoritmo
