Algoritmo PositivoNegativoO0Ej1
	Definir x Como Real;
	Escribir "Introduce un número y yo te diré si es positivo, negativo o zero";
	Escribir Sin Saltar "Número? ";
	Leer x;
	Si x>0 Entonces
		Escribir "Es positivo";
	SiNo
		Si x<0 Entonces
			Escribir "Es negativo";
		SiNo
			Escribir "Es el zero";
		FinSi
		
	FinSi
FinAlgoritmo
