//El usuario introduce un número y el programa le dice si está entre el 10 y el 20
Algoritmo Rango10a20Ej7
	Definir x Como Entero;//Definición de variable
	//Presentación e introducción de número
	Escribir Sin Saltar "Introduce un número y te diré si esta entre el 10 y 20: ";
	Leer x;
	//Procedimiento
	Si x>=10 & x<=20 Entonces
		Escribir "El número esta entre el 10 y el 20";
	SiNo
		Escribir "El número no esta entre el 10 y el 20";
	FinSi
	
FinAlgoritmo
